---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Latravel Tours',
  description = 'Curated tours rendered with Astro.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  :root {
    color-scheme: light;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  * {
    box-sizing: border-box;
  }
</style>
