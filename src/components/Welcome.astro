---
const { tours = [], featuredCount = 0 } = Astro.props;
const totalReviews = tours.reduce((sum, tour) => sum + tour.data.reviews, 0);
---

<div class="shell">
  <header class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Latravel Tours</p>
      <h1>Discover bookable Thailand experiences in a fast Astro marketplace.</h1>
      <p class="lede">
        The tours collection now loads through Astro Content Collections, giving you structured
        data, typed fields, and build-time validation for every published experience.
      </p>
      <div class="stats" aria-label="Marketplace overview">
        <div class="stat-card box">
          <span class="stat-value">{tours.length}</span>
          <span class="stat-label">Live tours</span>
        </div>
        <div class="stat-card box">
          <span class="stat-value">{featuredCount}</span>
          <span class="stat-label">Featured picks</span>
        </div>
        <div class="stat-card box">
          <span class="stat-value">{totalReviews.toLocaleString()}</span>
          <span class="stat-label">Verified reviews</span>
        </div>
      </div>
    </div>

    <aside class="hero-panel box">
      <p class="panel-label">Marketplace snapshot</p>
      <ul>
        <li><strong>Server rendered</strong><span>Zero client JS required for listing discovery.</span></li>
        <li><strong>Structured content</strong><span>Tour metadata is validated at build time.</span></li>
        <li><strong>SEO ready</strong><span>Clear headings, summaries, and pricing for each card.</span></li>
      </ul>
    </aside>
  </header>

  <main>
    <section class="section-heading">
      <div>
        <p class="eyebrow">Featured collection</p>
        <h2>Popular tours travelers can compare at a glance</h2>
      </div>
      <p class="section-copy">
        These cards are rendered directly from the <code>tours</code> collection in
        <code>src/content/</code>, so the homepage reflects your content source instead of placeholder starter markup.
      </p>
    </section>

    <section class="card-grid" aria-label="Tour listings">
      {
        tours.map((tour) => (
          <article id={tour.id} class="tour-card box">
            <div class="card-topline">
              <span class="category">{tour.data.category}</span>
              {tour.data.badge && <span class="badge">{tour.data.badge}</span>}
            </div>

            <div class="card-copy">
              <h3>{tour.data.title}</h3>
              <p class="location">{tour.data.city}, {tour.data.country}</p>
              <p class="summary">{tour.data.summary}</p>
            </div>

            <dl class="meta">
              <div>
                <dt>Duration</dt>
                <dd>{tour.data.duration}</dd>
              </div>
              <div>
                <dt>Rating</dt>
                <dd>{tour.data.rating.toFixed(1)} ★ · {tour.data.reviews} reviews</dd>
              </div>
            </dl>

            <div class="price-row">
              <div>
                <p class="price-label">From</p>
                <p class="price">${tour.data.priceFrom}</p>
              </div>
              <a href={`/#${tour.id}`} class="cta">View details</a>
            </div>
          </article>
        ))
      }
    </section>
  </main>
</div>

<style>
  :global(body) {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background:
      radial-gradient(circle at top, rgba(14, 165, 233, 0.18), transparent 30%),
      linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
    color: #0f172a;
  }

  .shell {
    min-height: 100%;
    padding: 24px;
  }

  .hero {
    display: grid;
    gap: 24px;
    align-items: stretch;
    margin: 0 auto 32px;
    max-width: 1120px;
  }

  .hero-copy,
  .hero-panel,
  .tour-card,
  .stat-card {
    backdrop-filter: blur(12px);
  }

  .eyebrow,
  .panel-label,
  .price-label,
  dt,
  .category {
    color: #0369a1;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2.5rem, 7vw, 4.75rem);
    line-height: 0.98;
  }

  .lede,
  .section-copy,
  .summary,
  .location,
  .hero-panel li span {
    color: #475569;
    line-height: 1.7;
  }

  .stats {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    margin-top: 24px;
  }

  .stat-card {
    display: grid;
    gap: 4px;
  }

  .stat-value {
    font-size: 1.8rem;
    font-weight: 800;
  }

  .stat-label {
    color: #475569;
  }

  .hero-panel {
    padding: 24px;
  }

  .hero-panel ul {
    display: grid;
    gap: 16px;
    padding: 0;
    margin: 20px 0 0;
    list-style: none;
  }

  .hero-panel li {
    display: grid;
    gap: 6px;
  }

  .section-heading {
    display: grid;
    gap: 12px;
    align-items: end;
    margin: 0 auto 20px;
    max-width: 1120px;
  }

  h2,
  h3,
  p {
    margin: 0;
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.4rem);
  }

  .card-grid {
    display: grid;
    gap: 18px;
    margin: 0 auto;
    max-width: 1120px;
  }

  .tour-card {
    display: grid;
    gap: 18px;
  }

  .card-topline,
  .price-row,
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .badge {
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(14, 165, 233, 0.12);
    color: #0369a1;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .card-copy {
    display: grid;
    gap: 8px;
  }

  h3 {
    font-size: 1.35rem;
  }

  .meta {
    border-top: 1px solid rgba(148, 163, 184, 0.25);
    padding-top: 18px;
  }

  .meta div {
    display: grid;
    gap: 6px;
  }

  dd {
    margin: 0;
    color: #0f172a;
    font-weight: 600;
  }

  .price {
    font-size: 2rem;
    font-weight: 800;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.2rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #0284c7, #2563eb);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    box-shadow: 0 14px 35px rgba(37, 99, 235, 0.28);
  }

  .box {
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 80px rgba(15, 23, 42, 0.08);
    padding: 20px;
  }

  code {
    font-size: 0.92em;
  }

  @media (min-width: 900px) {
    .hero,
    .section-heading {
      grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.9fr);
    }

    .card-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
