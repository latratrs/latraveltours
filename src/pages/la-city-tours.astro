---
import Layout from '../layouts/Layout.astro';

const quickFacts = [
  { label: 'Top-rated tours', value: '12' },
  { label: 'Average rating', value: '4.8/5' },
  { label: 'Free cancellation', value: 'Most experiences' },
];

const filterChips = ['Sightseeing', 'Studio tours', 'Beach escapes', 'Food & culture', 'Night tours'];

const tours = [
  {
    title: 'Los Angeles Hop-On Hop-Off Highlights Tour',
    neighborhood: 'Hollywood & Downtown',
    duration: '1 day pass',
    rating: 4.7,
    reviews: 1834,
    priceFrom: 54,
    badge: 'Likely to sell out',
    summary:
      'Cover Hollywood Boulevard, Beverly Hills, Santa Monica, and Downtown LA with flexible stops and open-top city views.',
    includes: 'Audio guide · Multiple routes · Mobile ticket',
  },
  {
    title: 'Warner Bros. Studio Tour with Transfers',
    neighborhood: 'Burbank',
    duration: '4 hours',
    rating: 4.9,
    reviews: 1268,
    priceFrom: 119,
    badge: 'Editor’s pick',
    summary:
      'Step behind the scenes of iconic sets, sound stages, and the backlot with round-trip transfers from central Los Angeles.',
    includes: 'Studio entry · Shuttle transfer · Small group',
  },
  {
    title: 'Santa Monica, Venice Beach & Malibu Explorer',
    neighborhood: 'Westside Coast',
    duration: '6 hours',
    rating: 4.8,
    reviews: 942,
    priceFrom: 89,
    badge: 'Free cancellation',
    summary:
      'Cruise the Pacific Coast Highway, stroll the Santa Monica Pier, and soak in beach culture from Venice to Malibu.',
    includes: 'Guide · Scenic stops · Hotel pickup',
  },
];
---

<Layout
  title="LA City Tours | Compare Los Angeles sightseeing experiences"
  description="Browse Los Angeles city tours with Viator-style cards, quick facts, and clear pricing for popular sightseeing experiences."
>
  <div class="shell">
    <main class="page">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Los Angeles tours</p>
          <h1>Compare LA city tours with fast, scannable booking cards.</h1>
          <p class="lede">
            Explore sightseeing, studio, and coastal day tours in a marketplace layout inspired
            by modern travel booking pages.
          </p>

          <div class="fact-grid" aria-label="Los Angeles tour overview">
            {
              quickFacts.map((fact) => (
                <div class="fact box">
                  <span class="fact-value">{fact.value}</span>
                  <span class="fact-label">{fact.label}</span>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="hero-panel box" aria-label="Why book LA city tours">
          <p class="panel-label">Why travelers book LA</p>
          <ul>
            <li>Compare popular routes across Hollywood, Downtown, and the coast.</li>
            <li>See ratings, review volume, and starting price before opening a listing.</li>
            <li>Keep the page static-first for fast discovery and strong SEO.</li>
          </ul>
        </aside>
      </section>

      <section class="toolbar box" aria-label="Tour category filters">
        <div>
          <p class="eyebrow">Popular filters</p>
          <h2>Find the right LA experience faster</h2>
        </div>

        <div class="chip-row">
          {
            filterChips.map((chip) => (
              <span class="chip">{chip}</span>
            ))
          }
        </div>
      </section>

      <section class="listing-grid" aria-label="Los Angeles city tours">
        {
          tours.map((tour) => (
            <article class="tour-card box">
              <div class="card-head">
                <span class="location">{tour.neighborhood}</span>
                <span class="badge">{tour.badge}</span>
              </div>

              <div class="card-copy">
                <h3>{tour.title}</h3>
                <p class="summary">{tour.summary}</p>
              </div>

              <dl class="meta">
                <div>
                  <dt>Duration</dt>
                  <dd>{tour.duration}</dd>
                </div>
                <div>
                  <dt>Rating</dt>
                  <dd>{tour.rating.toFixed(1)} ★ · {tour.reviews.toLocaleString()} reviews</dd>
                </div>
                <div>
                  <dt>Includes</dt>
                  <dd>{tour.includes}</dd>
                </div>
              </dl>

              <div class="price-row">
                <div>
                  <p class="price-label">From</p>
                  <p class="price">${tour.priceFrom}</p>
                </div>
                <a class="cta" href="/">Back to homepage</a>
              </div>
            </article>
          ))
        }
      </section>
    </main>
  </div>
</Layout>

<style>
  :global(body) {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background:
      radial-gradient(circle at top, rgba(37, 99, 235, 0.16), transparent 32%),
      linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
    color: #0f172a;
  }

  .shell {
    min-height: 100%;
    padding: 24px;
  }

  .page,
  .hero,
  .listing-grid {
    display: grid;
    gap: 24px;
  }

  .page {
    margin: 0 auto;
    max-width: 1120px;
  }

  .hero-copy,
  .hero-panel,
  .tour-card,
  .fact,
  .toolbar {
    backdrop-filter: blur(12px);
  }

  .eyebrow,
  .panel-label,
  .price-label,
  dt,
  .location {
    color: #0369a1;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    margin-bottom: 12px;
    max-width: 12ch;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 0.98;
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
  }

  h3 {
    font-size: 1.4rem;
  }

  .lede,
  .summary,
  .hero-panel li,
  .fact-label {
    color: #475569;
    line-height: 1.7;
  }

  .fact-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    margin-top: 24px;
  }

  .fact {
    display: grid;
    gap: 4px;
  }

  .fact-value {
    font-size: 1.7rem;
    font-weight: 800;
  }

  .hero-panel {
    padding: 24px;
  }

  .hero-panel ul {
    display: grid;
    gap: 14px;
    margin: 18px 0 0;
    padding-left: 18px;
  }

  .toolbar {
    display: grid;
    gap: 18px;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .chip {
    padding: 0.65rem 0.95rem;
    border: 1px solid rgba(14, 165, 233, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    color: #0f172a;
    font-weight: 600;
  }

  .listing-grid {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .tour-card {
    display: grid;
    gap: 18px;
  }

  .card-head,
  .price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .badge {
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(14, 165, 233, 0.12);
    color: #0369a1;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .card-copy {
    display: grid;
    gap: 10px;
  }

  .meta {
    display: grid;
    gap: 14px;
    border-top: 1px solid rgba(148, 163, 184, 0.25);
    padding-top: 18px;
  }

  .meta div {
    display: grid;
    gap: 6px;
  }

  dd {
    margin: 0;
    color: #0f172a;
    font-weight: 600;
  }

  .price {
    font-size: 2rem;
    font-weight: 800;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.2rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #0284c7, #2563eb);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    box-shadow: 0 14px 35px rgba(37, 99, 235, 0.28);
  }

  .box {
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 80px rgba(15, 23, 42, 0.08);
    padding: 20px;
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.85fr);
      align-items: stretch;
    }
  }
</style>
