---
import { getCollection } from 'astro:content';
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';

const tours = (await getCollection('tours')).sort((left, right) => {
  if (left.data.featured === right.data.featured) {
    return right.data.rating - left.data.rating;
  }

  return Number(right.data.featured) - Number(left.data.featured);
});

const featuredCount = tours.filter((tour) => tour.data.featured).length;
---

<Layout
  title="Latravel Tours | Thailand experiences curated for mobile-first discovery"
  description="Browse featured Thailand tours with ratings, clear pricing, and fast Astro-rendered marketplace cards."
>
  <Welcome tours={tours} featuredCount={featuredCount} />
</Layout>
